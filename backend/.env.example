# Copy this file to .env and fill in real values before running the server.
# NEVER commit your real .env file to version control.

# Server
PORT=4000
NODE_ENV=development

# CORS - the URL(s) your frontend is served from
FRONTEND_ORIGIN=http://localhost:5500

# JWT secrets - generate strong random strings, e.g. `openssl rand -hex 64`
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# First admin account, created automatically the first time the server runs
# if no admin exists yet. Change these immediately after first login.
ADMIN_NAME=Church Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_Now123!

# SQLite database file location
DB_PATH=./data/church.db
