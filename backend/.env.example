# Copy this file to .env and fill in real values before running the server.
# NEVER commit your real .env file to version control.

# Server
PORT=4000
NODE_ENV=development

# CORS - the URL(s) your frontend is served from
FRONTEND_ORIGIN=http://localhost:5500

# JWT secrets - generate strong random strings, e.g. `openssl rand -hex 64`
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# First admin account, created automatically the first time the server runs
# if no admin exists yet. Change these immediately after first login.
ADMIN_NAME=Church Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_Now123!

# SQLite database file location
DB_PATH=./data/church.db

# ---------------------------------------------------------------------
# Email (SMTP) — optional but recommended.
# Works with ANY standard SMTP provider: SendGrid, Mailgun, Postmark,
# Amazon SES, Gmail SMTP, or your church's own mail host.
#
# If SMTP_HOST is left blank, the app still works — emails (password
# resets, verification links, confirmations) are just printed to the
# server console instead of actually sent. Fine for local testing, NOT
# fine for real use — fill this in before launch.
#
# Example values for a few common providers:
#   SendGrid : SMTP_HOST=smtp.sendgrid.net   SMTP_PORT=587  SMTP_USER=apikey            SMTP_PASS=<your API key>
#   Mailgun  : SMTP_HOST=smtp.mailgun.org    SMTP_PORT=587  SMTP_USER=<mailgun user>    SMTP_PASS=<mailgun password>
#   Gmail    : SMTP_HOST=smtp.gmail.com      SMTP_PORT=587  SMTP_USER=<your gmail>      SMTP_PASS=<an "app password", not your normal password>
# ---------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Grace Community Church <no-reply@example.com>

# Optional: if set, staff get an email whenever a new prayer request or
# "Connect With Us" registration comes in. Leave blank to disable.
ADMIN_NOTIFICATION_EMAIL=

# ---------------------------------------------------------------------
# SMS & WhatsApp (Twilio) — optional but recommended if members choose
# "phone" or "whatsapp" as their preferred contact method.
#
# If TWILIO_ACCOUNT_SID is left blank, the app still works — SMS/WhatsApp
# messages are just printed to the server console instead of actually
# sent. Fine for local testing, NOT fine for real use — fill this in
# before launch if you want those contact preferences to actually work.
#
# Get these from https://console.twilio.com after creating a free trial
# account. TWILIO_FROM_NUMBER is the Twilio phone number you're assigned
# (for WhatsApp, it's the number from your Twilio WhatsApp sender setup —
# see https://www.twilio.com/docs/whatsapp for enabling WhatsApp).
# ---------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
